# App Configuration
APP_NAME="Nextbin.in Automation Server"
DEBUG=true
API_V1_STR="/api/v1"
HOST=0.0.0.0
PORT=8000

# Security Configurations
# Generate a secure secret key using: openssl rand -hex 32
JWT_SECRET_KEY="your-super-secret-jwt-key-change-this-in-production"
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Credential Encryption Key
# Generate a Fernet key using: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY="your-fernet-encryption-key-for-storing-credentials-securely"

# Database Configuration
# In Termux, files are written locally. 
DATABASE_URL="sqlite+aiosqlite:///./data/nextbin.db"

# Background Huey Queue Configuration
QUEUE_DB_PATH="./data/huey_queue.db"

# Instagram Login Settings (Optional defaults or configurations)
INSTAGRAM_TIMEOUT=30
INSTAGRAM_MAX_RETRIES=3
